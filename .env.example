# Axis Server backend.
# Real EtherCAT device: pysoem
# Virtual mock axes: mock
AXIS_SERVER_BACKEND=pysoem

# EtherCAT NIC name.
# Used only when AXIS_SERVER_BACKEND=pysoem.
PYSOEM_INTERFACE=enp1s0

# Number of axes.
# mock: number of virtual axes
# pysoem: number of connected EtherCAT slaves
PYSOEM_AXIS_COUNT=1

# TCP port used by Axis Server and Axis Panel.
PYSOEM_AXIS_SERVER_PORT=15000

# Axis Server TCP endpoint used by ROS Bridge.
# Windows ROS container -> Ubuntu Axis Server: 192.168.0.12
# Same-host ROS container -> local Axis Server: 127.0.0.1
CIA402_AXIS_SERVER_HOST=192.168.0.12
CIA402_AXIS_SERVER_PORT=15000

# ROS Bridge automatically requests Axis Server command authority after TCP
# connection. Set to 0 if another client should hold authority explicitly.
CIA402_AUTO_REQUEST_AUTHORITY=1

# FollowJointTrajectory action completion settings used by ROS Bridge.
# Units follow the joint position units used by /joint_trajectory.
# Set result timeout to 0.0 to wait until all axes reach target or goal is canceled.
CIA402_ACTION_GOAL_TOLERANCE=0.01
CIA402_ACTION_RESULT_TIMEOUT=0.0

# Axis Server process-data cycle time in seconds.
PYSOEM_CYCLE_TIME=0.01

# Initial Axis Server motion limits.
PYSOEM_MAX_VELOCITY=50.0
PYSOEM_ACCELERATION=100.0
PYSOEM_DECELERATION=100.0

# Axis Server status log period in seconds. Set 0.0 to disable status logs.
PYSOEM_STATUS_LOG_PERIOD=1.0

# Axis Server EtherCAT cycle statistics log period in seconds.
PYSOEM_CYCLE_STATS_PERIOD=1.0

# CSP velocity scaling.
# Example: 1000 count/mm means panel velocity 1000 becomes 1000000 count/s.
PYSOEM_CSP_COUNTS_PER_UNIT=1000.0

# Low-pass filter alpha for derived velocity display.
# 1.0 disables filtering.
PYSOEM_DERIVED_VELOCITY_ALPHA=0.2

# Initial motion mode.
# pp is recommended for normal non-real-time host operation.
# csp is available for cyclic position streaming tests.
PYSOEM_MOTION_MODE=pp

# Docker Compose project name.
COMPOSE_PROJECT_NAME=ros2_cia402_pysoem
